# .env.example
# Copy this file to .env for local development
# In production, set these variables in your hosting dashboard (e.g. Render/Railway)

# Connection string for your MongoDB Atlas cluster or local instance
MONGO_URI=mongodb://127.0.0.1:27017/

# Resend API key for sending enquiry emails (re_...)
RESEND_API_KEY=your_resend_api_key_here

# The email address that will receive the enquiries
RECIPIENT_EMAIL=your_real_email@example.com

# Flask Secret Key for sessions (change this in production)
SECRET_KEY=nova-polymers-2025-super-secret

# Admin login credentials
ADMIN_USER=admin
ADMIN_PASS=admin123
